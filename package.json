{
  "name": "voting-tool",
  "version": "1.0.0",
  "private": true,
  "main": "api/index.js",
  "scripts": {
    "init-firebase": "node init-firebase.js",
    "diagnose-credentials": "node scripts/diagnose-firebase-credentials.js",
    "bootstrap-tenancy": "node scripts/bootstrap-tenancy.js",
    "bootstrap-tenancy:dry-run": "node scripts/bootstrap-tenancy.js --dry-run",
    "test-tenant:create": "node scripts/manage-test-tenant.js create",
    "test-tenant:create:dry-run": "node scripts/manage-test-tenant.js create --dry-run",
    "test-tenant:delete": "node scripts/manage-test-tenant.js delete",
    "migrate-suggestion-types": "node scripts/migrate-suggestion-types.js",
    "migrate-ticketing": "node scripts/migrate-to-ticketing-v1.js",
    "migrate-ticketing:dry-run": "node scripts/migrate-to-ticketing-v1.js --dry-run",
    "start": "node api/index.js",
    "dev": "node api/index.js",
    "build": "echo 'Build complete - Node.js API ready'",
    "vercel-build": "echo 'Vercel build complete'",
    "tenant:create": "node scripts/create-tenant.js",
    "tenant:create:dry-run": "node scripts/create-tenant.js --dry-run",
    "db:migrate": "node scripts/migrate-db.js",
    "db:migrate:status": "node scripts/migrate-db.js --status",
    "test": "node --test tests/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase-admin": "^13.5.0",
